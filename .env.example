# Acta — Environment Variables (foundation)
# This file is documentation only. DO NOT commit real secrets.
# DO NOT set ALLOW_REAL_STUDENT_DATA=true until D-003 (FERPA DPA) is resolved.

# ───── Application ─────
APP_ENV=development               # development | staging | production
FRONTEND_PORT=3000
BACKEND_PORT=4000

# ───── Database (D-009, D-010 — local Docker Postgres for foundation only) ─────
DATABASE_URL=postgresql://acta:acta@localhost:5432/acta_dev

# ───── Authentication (DEFERRED — placeholder only at foundation) ─────
# Auth provider is a pending L3 decision. Foundation routes return 401 if Authorization
# header is missing. Do not put real secrets here at foundation stage.
AUTH_PLACEHOLDER_TOKEN=dev-placeholder-token

# ───── AI / LLM (D-003 — Anthropic Claude for development with SYNTHETIC DATA ONLY) ─────
# Leave both empty to use the deterministic stub provider (D-022). Real keys MUST
# only live in your local .env (which is .gitignored). Never paste them into
# docs, tests, source files, screenshots, commits, or chat transcripts. If a key
# is ever exposed, rotate it immediately on the provider dashboard.
OPENAI_API_KEY=                          # placeholder only — real key lives in local .env
OPENAI_MODEL=gpt-4o-mini                 # default OpenAI model (cheap + fast); override as needed
ANTHROPIC_API_KEY=                       # placeholder only — real key lives in local .env
ANTHROPIC_MODEL=claude-haiku-4-5-20251001 # default dev model (D-026); override as needed
# Master kill-switch — must remain "false" until a signed FERPA DPA exists with
# the selected production AI provider AND a Level 3 decision has explicitly
# enabled real LLM calls. The backend's stub-by-default fallback (D-022) means
# leaving USE_REAL_LLM=false is safe even when an API key is set.
USE_REAL_LLM=false

# ───── Voice verification (D-048 — async voice answers via OpenAI gpt-4o-mini-transcribe) ─────
# Master kill-switch for real transcription. OpenAI transcription only activates when
# this is true AND USE_REAL_LLM=true AND OPENAI_API_KEY is set. Otherwise the
# deterministic stub provider is used. No raw audio is persisted anywhere
# regardless of this setting.
USE_REAL_VOICE=false
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
MAX_VOICE_SECONDS=180

# ───── Ledger signing (D-015 — Ed25519 via Node crypto for dev) ─────
# Generate with: pnpm --filter @acta/backend exec node -e "import('node:crypto').then(c=>{const{publicKey,privateKey}=c.generateKeyPairSync('ed25519');console.log('LEDGER_SIGNING_PRIVATE_KEY_PEM='+JSON.stringify(privateKey.export({type:'pkcs8',format:'pem'})));console.log('LEDGER_SIGNING_PUBLIC_KEY_PEM='+JSON.stringify(publicKey.export({type:'spki',format:'pem'})));})"
# Production KMS infrastructure is DEFERRED — do not use these keys for production.
LEDGER_SIGNING_PRIVATE_KEY_PEM=
LEDGER_SIGNING_PUBLIC_KEY_PEM=

# ───── FERPA / Compliance guard (D-003) ─────
# MUST remain "false" until a signed FERPA DPA exists with the selected production AI provider.
# The backend will refuse to boot if this is "true" and FERPA_DPA_REFERENCE is empty.
ALLOW_REAL_STUDENT_DATA=false
FERPA_DPA_REFERENCE=              # set to the DPA contract reference once signed

# ───── Multi-tenancy ─────
# Foundation does not implement isolation yet; tenant_id will be added to the future ledger schema.
DEFAULT_TENANT_ID=dev-tenant

# ───── LMS Integration (Q5 — DEFERRED to v1.5) ─────
# Foundation does NOT use these. Reserved for future LTI 1.3.
LMS_CLIENT_ID=
LMS_CLIENT_SECRET=

# ───── Live oral / WebRTC (Q4 — DEFERRED to v2) ─────
# Foundation does NOT use these. Reserved for future audio modality.
WEBRTC_SIGNALING_URL=
