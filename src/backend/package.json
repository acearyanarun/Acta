{
  "name": "@acta/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=../../.env dist/server.js",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx --env-file-if-exists=../../.env src/db/migrate.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.32.1",
    "drizzle-orm": "0.36.0",
    "fastify": "5.0.0",
    "postgres": "3.4.5",
    "ulid": "2.3.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.16.13",
    "drizzle-kit": "0.28.0",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  }
}
